APP_MODE=public_demo
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
API_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
DATABASE_URL=sqlite+aiosqlite:///./data/quant.db
VALKEY_URL=
ARTIFACT_BACKEND=local
ARTIFACT_ROOT=artifacts/local
RATE_LIMIT_SECRET=replace-with-at-least-32-characters
POSTGRES_PASSWORD=development-only-change-me
BACKTEST_EAGER=true
AUTO_CREATE_SCHEMA=true
TRUST_PROXY=false
OCI_BUCKET_NAME=
OCI_NAMESPACE=
OCI_REGION=ap-seoul-1
OCI_COMPARTMENT_ID=
PUBLIC_DOMAIN=
RESEARCH_ROOT=data/research
RESEARCH_HISTORY_YEARS=10
RESEARCH_SCORE_LOOKBACK_SESSIONS=400
RESEARCH_BATCH_SIZE=20
RESEARCH_MAX_RETRIES=3
RESEARCH_MINIMUM_GROUP_ASSETS=30
RESEARCH_AUTO_SYNC=true
RESEARCH_POLL_SECONDS=900
# Local research only. pykrx uses these for an authenticated KRX session.
KRX_ID=
KRX_PW=
# Optional fallback files when authenticated KRX collection is unavailable.
RESEARCH_KRX_STOCK_CSV=
RESEARCH_KRX_ETF_CSV=
